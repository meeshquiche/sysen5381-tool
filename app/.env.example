# Copy to `.env` or `.env.txt` in this folder. Never commit real secrets.

# --- Drug info → multi-agent AI (default: Ollama) ---
# AI_BACKEND=ollama
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2:latest

# Optional: use OpenAI instead of Ollama
# AI_BACKEND=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- openFDA (optional) ---
# OPENFDA_API_KEY=
